// Memory Match — Sound effects

playFlip = function()
	audio.beep("sine tempo 18000 volume 15 span 50 G5")
end

playMatch = function()
	audio.beep("sine tempo 8000 volume 20 span 80 C5 E5 G5")
end

playNoMatch = function()
	audio.beep("sine tempo 6000 volume 12 span 100 E4 C4")
end

playWin = function()
	audio.beep("sine tempo 5000 volume 22 span 150 C5 E5 G5 C6 E6")
end

playMenuTap = function()
	audio.beep("sine tempo 20000 volume 12 span 30 C6")
end
