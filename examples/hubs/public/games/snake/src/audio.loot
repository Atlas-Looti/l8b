// Snake — Sound effects

playEat = function()
	audio.beep("sine tempo 12000 volume 18 span 60 E5 A5")
end

playTurn = function()
	audio.beep("sine tempo 25000 volume 8 span 30 C5")
end

playDie = function()
	audio.beep("sine tempo 4000 volume 20 span 200 E5 C5 A4 E4")
end

playStart = function()
	audio.beep("sine tempo 8000 volume 15 span 80 C5 E5 G5")
end
