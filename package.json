{
	"name": "atlas-looti-game-enggine",
	"version": "0.1.0",
	"description": "Atlas Looti Game Enggine",
	"private": true,
	"workspaces": [
		"examples/**/*",
		"packages/**/*",
		"scripts/**/*",
		"apps/**/*",
		"!**/dist/**",
		"!**/next/**",
		"!**/l8b/**",
		"!**/.vscode-test/**"
	],
	"scripts": {
		"build": "bunx turbo run build",
		"dev": "bunx turbo run dev --concurrency=15",
		"lint": " biome check --write .",
		"lint:check": " biome check .",
		"format": " biome format --write .",
		"format:check": " biome format .",
		"check-types": "bunx turbo run check-types",
		"test": "bunx turbo run test",
		"test:e2e": "bunx turbo run test:e2e",
		"test:watch": "bunx turbo run test:watch",
		"test:coverage": "bunx turbo run test:coverage",
		"new": "bun scripts/new-package.mjs",
		"clean": "bun scripts/clean.mjs --dist",
		"clean:all": "bun scripts/clean.mjs --all",
		"ci": "bun run lint:check && bun run format:check && bun run check-types && bun run build && bun run test",
		"start:fish": "cd examples/fish && bun run preview",
		"start:vscode:e2e": "bunx turbo run test:e2e --filter=@al8b/vscode",
		"changeset": "changeset add",
		"changeset-version": "changeset version",
		"changeset-publish": "node scripts/publish.mjs",
		"changeset-status": "changeset status",
		"release": "bun run changeset-version && bun run changeset-publish"
	},
	"devDependencies": {
		"@changesets/changelog-github": "0.5.2",
		"@changesets/cli": "2.30.0",
		"@types/bun": "1.3.11",
		"@vitest/ui": "4.1.2",
		"jsdom": "29.0.0",
		"prettier": "3.8.1",
		"turbo": "2.9.3",
		"typescript": "6.0.2"
	},
	"engines": {
		"node": "^24.0.0",
		"bun": ">=1.3.0"
	},
	"packageManager": "bun@1.3.9",
	"dependencies": {
		"@swc/core": "1.15.24",
		"biome": "0.3.3",
		"buffer": "6.0.3",
		"sirv": "3.0.2",
		"tsup": "8.5.1",
		"vitest": "4.1.2"
	},
	"publishConfig": {
		"access": "public"
	}
}
