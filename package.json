{
	"name": "l8b",
	"version": "1.0.1",
	"description": "Looti Engine",
	"private": true,
	"workspaces": [
		"examples/**/*",
		"packages/**/*",
		"scripts/**/*",
		"apps/**/*",
		"!**/dist/**",
		"!**/next/**",
		"!**/l8b/**",
		"!**/.vscode-test/**"
	],
	"scripts": {
		"docs:dev": "cd site && bun run dev",
		"docs:build": "cd site && bun run build",
		"docs:preview": "cd site && bun run preview",
		"build": "turbo run build ",
		"dev": "turbo run dev --concurrency=15",
		"lint": " biome check --write .",
		"lint:check": " biome check .",
		"format": " biome format --write .",
		"format:check": " biome format .",
		"check-types": "turbo run check-types",
		"test": "turbo run test",
		"test:watch": "turbo run test:watch",
		"test:coverage": "turbo run test:coverage",
		"new": "node scripts/new-package.mjs",
		"clean": "node scripts/clean.mjs --all",
		"ci": "bun run lint:check && bun run format:check && bun run check-types && bun run build && bun run test",
		"changeset": "changeset",
		"changeset:version": "bun install && changeset version",
		"changeset:publish": "bun run changeset:prepublish && changeset publish",
		"changeset:prepublish": "turbo build --filter='./packages/**'",
		"publish-packages": "turbo run build && changeset version && changeset publish",
		"start:fish": "cd examples/framework/fish && bun run preview",
		"start:bird": "cd examples/framework/bird && bun run preview"
	},
	"devDependencies": {
		"@changesets/cli": "2.30.0",
		"@types/bun": "1.3.11",
		"@vitest/ui": "4.1.2",
		"jsdom": "29.0.0",
		"prettier": "3.8.1",
		"turbo": "2.9.3",
		"typescript": "6.0.2"
	},
	"engines": {
		"node": "^24.0.0",
		"bun": ">=1.3.0"
	},
	"packageManager": "bun@1.3.9",
	"dependencies": {
		"@swc/core": "^1.15.21",
		"biome": "^0.3.3",
		"buffer": "^6.0.3",
		"changeset": "^0.2.6",
		"sirv": "^3.0.2",
		"tsup": "^8.5.1",
		"vitest": "^4.0.7"
	},
	"publishConfig": {
		"access": "public"
	}
}
