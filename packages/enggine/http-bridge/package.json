{
  "name": "@al8b/http-bridge",
  "version": "0.1.14",
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "bun --bun ../../../scripts/clean-package.mjs dist",
    "test": "vitest run --passWithNoTests"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@al8b/runtime": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  },
  "keywords": [
    "runtime",
    "http",
    "bridge",
    "api",
    "fetch"
  ],
  "publishConfig": {
    "access": "public"
  }
}
