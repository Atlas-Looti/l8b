{
	"name": "@al8b/lootiscript",
	"version": "0.1.6",
	"sideEffects": false,
	"files": [
		"dist/**/*",
		"README.md",
		"package.json"
	],
	"scripts": {
		"build": "tsup",
		"clean": "bun --bun ../../../scripts/clean-package.mjs dist",
		"test": "vitest run --passWithNoTests",
		"check-types": "tsc --noEmit"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@al8b/diagnostics": "workspace:*",
		"@al8b/stdlib": "workspace:*"
	},
	"keywords": [
		"lootiscript"
	],
	"publishConfig": {
		"access": "public"
	}
}
