{
	"name": "@al8b/framework-watcher",
	"version": "0.1.1",
	"sideEffects": false,
	"files": [
		"dist/**/*",
		"README.md",
		"package.json"
	],
	"scripts": {
		"build": "tsup",
		"clean": "bun --bun ../../../scripts/clean-package.mjs dist",
		"test": "vitest run --passWithNoTests"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"dependencies": {
		"@al8b/framework-shared": "workspace:*",
		"chokidar": "^4.0.1"
	},
	"devDependencies": {},
	"keywords": [
		"l8b",
		"framework",
		"watcher"
	],
	"publishConfig": {
		"access": "public"
	}
}
