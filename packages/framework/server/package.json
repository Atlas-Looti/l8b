{
	"name": "@al8b/framework-server",
	"version": "0.1.2",
	"sideEffects": false,
	"files": [
		"dist/**/*",
		"README.md",
		"package.json"
	],
	"scripts": {
		"build": "tsup",
		"clean": "bun --bun ../../../scripts/clean-package.mjs dist",
		"test": "vitest run --passWithNoTests"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"dependencies": {
		"@al8b/framework-shared": "workspace:*",
		"@al8b/framework-config": "workspace:*",
		"@al8b/compiler": "workspace:*",
		"@al8b/framework-watcher": "workspace:*",
		"@al8b/framework-html": "workspace:*",
		"@al8b/runtime": "workspace:*",
		"esbuild": "^0.24.0",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@types/ws": "^8.5.14"
	},
	"keywords": [
		"l8b",
		"framework",
		"server"
	],
	"publishConfig": {
		"access": "public"
	}
}
