{
	"name": "@al8b/diagnostics",
	"version": "0.1.1",
	"description": "Centralized diagnostics system for error and warning messages",
	"type": "module",
	"sideEffects": false,
	"files": [
		"dist/**/*",
		"package.json",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup",
		"clean": "bun --bun ../../../scripts/clean-package.mjs dist",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.9.3"
	},
	"keywords": [
		"diagnostics",
		"errors",
		"warnings",
		"l8b"
	],
	"publishConfig": {
		"access": "public"
	}
}
