{
  "name": "@al8b/image",
  "version": "0.1.14",
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "bun --bun ../../../scripts/clean-package.mjs dist",
    "test": "vitest run --passWithNoTests"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "dependencies": {},
  "keywords": [
    "image",
    "canvas",
    "graphics"
  ],
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@vitest/ui": "^4.0.9",
    "happy-dom": "^20.0.10",
    "jsdom": "^24.1.3",
    "vitest": "^4.0.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
