{
	"name": "@l8b/screen",
	"version": "1.0.11",
	"sideEffects": false,
	"files": [
		"dist/**/*",
		"README.md",
		"package.json"
	],
	"scripts": {
		"build": "tsup",
		"clean": "rm -rf dist",
		"test": "vitest run --passWithNoTests"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"dependencies": {
		"@l8b/diagnostics": "workspace:*",
		"@l8b/image": "workspace:*",
		"@l8b/map": "workspace:*",
		"@l8b/sprites": "workspace:*"
	},
	"keywords": [
		"screen"
	],
	"publishConfig": {
		"access": "public"
	}
}
