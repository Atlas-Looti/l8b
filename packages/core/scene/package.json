{
	"name": "@l8b/scene",
	"version": "1.0.11",
	"description": "Scene management and routing system for L8B",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"clean": "rm -rf dist .turbo node_modules",
		"test": "vitest run --passWithNoTests"
	},
	"dependencies": {
		"@l8b/diagnostics": "workspace:*"
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.9.3"
	},
	"publishConfig": {
		"access": "public"
	}
}
