{
	"name": "@al8b/palette",
	"version": "0.1.13",
	"sideEffects": false,
	"files": [
		"dist/**/*",
		"README.md",
		"package.json"
	],
	"scripts": {
		"build": "tsup",
		"clean": "bun --bun ../../../scripts/clean-package.mjs dist",
		"test": "vitest run --passWithNoTests"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"dependencies": {},
	"keywords": [
		"palette"
	],
	"publishConfig": {
		"access": "public"
	}
}
